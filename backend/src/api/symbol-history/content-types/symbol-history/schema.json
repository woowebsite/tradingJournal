{
  "kind": "collectionType",
  "collectionName": "symbol_histories",
  "info": {
    "singularName": "symbol-history",
    "pluralName": "symbol-histories",
    "displayName": "SymbolHistory"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "open": {
      "type": "float"
    },
    "high": {
      "type": "float"
    },
    "low": {
      "type": "float"
    },
    "close": {
      "type": "float"
    },
    "date": {
      "type": "datetime"
    },
    "volume": {
      "type": "float"
    },
    "symbol": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::symbol.symbol",
      "inversedBy": "symbol_histories"
    }
  }
}
