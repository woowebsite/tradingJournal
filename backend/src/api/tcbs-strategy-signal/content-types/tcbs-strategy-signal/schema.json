    },
    "Volume": {
      "type": "biginteger"
    },
    "Sig": {
      "type": "integer"
    },
    "strategyKey": {
      "type": "string",
      "required": true
    },
    "ticker": {
      "type": "string",
      "required": true
    },
    "strategy": {
      "type": "relation",
