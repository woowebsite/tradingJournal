{
  "kind": "collectionType",
  "collectionName": "trade_details",
  "info": {
    "singularName": "trade-detail",
    "pluralName": "trade-details",
    "displayName": "TradeDetail"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "price": {
      "type": "float"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Buy",
        "Sell"
      ]
    },
    "volume": {
      "type": "float"
    },
    "signal": {
      "type": "enumeration",
      "enum": [
        "Entry",
        "TakeProfit",
        "Stoploss",
        "Exit"
      ]
    },
    "screenshot": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "date": {
      "type": "datetime"
    },
    "note": {
      "type": "blocks"
    },
    "trade": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::trade.trade",
      "inversedBy": "trade_details"
    }
  }
}
